%TAG !u! tag:unity3d.com,2011:
--- !u!114 &11400000
MonoBehaviour:
  m_ObjectHideFlags: 0
  m_CorrespondingSourceObject: {fileID: 0}
  m_PrefabInstance: {fileID: 0}
  m_PrefabAsset: {fileID: 0}
  m_GameObject: {fileID: 0}
  m_Enabled: 1
  m_EditorHideFlags: 0
  m_Script: {fileID: 11500000, guid: 9b358ab4fd88811498213e60b44d66dd, type: 3}
  m_Name: LiShihua
  m_EditorClassIdentifier: 
  characterId: Char_Danwol_01
  characterName: "\uB9AC \uC2DC\uD654 (\u674E\u8A69\u83EF)"
  characterName_eng: "Lei\u2075 Si\xB9 Waa\u2074"
  dialogue: 
  portrait: {fileID: 0}
  fullBodyImage: {fileID: 0}
  silhouette: {fileID: 0}
  age: 24
  job: "\uACF5\uC791\uCCAD \uCC28\uAD00 \uBCF4\uC88C"
  height: 161
  weight: 51
  notes: "\uAD6C\uB8E1\uCC44\uC131\uC758 \uC9C8\uC11C\uB97C \uAC00\uB974\uB294 \uC11C\uB9BF\uBC1C
    \uAC19\uC740 \uBCF4\uC88C\uAD00. \uC6B0\uC544\uD55C \uBBF8\uC18C \uB4A4\uC5D0
    \uAC10\uC815\uC744 \uAC10\uCD98 \uCC44, \uB2E8 \uD55C \uCE58\uC758 \uC624\uCC28\uB3C4
    \uD5C8\uC6A9\uD558\uC9C0 \uC54A\uB294 \uC644\uBCBD\uD55C \uD310\uB2E8\uC73C\uB85C
    \uADE0\uD615\uC744 \uBC14\uB85C\uC7A1\uB294\uB2E4. \uACFC\uAC70\uC758 \uC778\uC5F0\uC740
    \uC624\uC9C1 \uADF8\uB140\uB9CC\uC774 \uC544\uB294 \uBE44\uBC00\uB85C \uB0A8\uC544
    \uC788\uB2E4."
  stories:
  - title: "\uCD9C\uC2E0 \uBC0F \uC131\uC7A5 \uBC30\uACBD"
    content: "\uB9AC \uC2DC\uD654\uB294 \uBA85\uB9DD \uB192\uC740 \uADC0\uC871 \uB9AC
      \uAC00\uBB38\uC758 \uC678\uB3D9\uB538\uB85C \uCD9C\uC0DD\uD558\uC600\uB2E4.
      \uBD80\uCE5C\uC740 \uAC00\uBB38\uC758 \uC218\uC7A5\uC73C\uB85C\uC11C \uC5C4\uACA9\uD558\uACE0
      \uB0C9\uC815\uD55C \uC778\uBB3C\uB85C, \uD53C\uB300\uC0C1\uC790\uB97C \uC5B4\uB9B0
      \uC2DC\uC808\uBD80\uD130 \uD6C4\uACC4\uC790 \uC218\uC900\uC73C\uB85C \uD6C8\uC721\uD558\uC600\uB2E4.
      \uBC18\uBA74 \uBAA8\uCE5C\uC740 \uC628\uD654\uD55C \uC131\uD488\uC744 \uC9C0\uB154\uC73C\uB098
      \uBCD1\uC57D\uD558\uC5EC \uC7A5\uAE30\uAC04 \uC694\uC591\uC744 \uBC18\uBCF5\uD558\uC600\uACE0,
      \uC774\uB85C \uC778\uD574 \uB300\uC0C1\uC790\uB294 \uC815\uC11C\uC801 \uC720\uB300
      \uD615\uC131\uC5D0 \uC81C\uD55C\uC744 \uACAA\uC740 \uAC83\uC73C\uB85C \uD310\uB2E8\uB41C\uB2E4.\n\n\uC678\uB3D9\uC784\uC5D0\uB3C4
      \uBD88\uAD6C\uD558\uACE0, \uAC00\uBB38 \uB0B4\uBD80\uC5D0\uC11C\uB294 \uB0A8\uC790
      \uD6C4\uACC4\uC790\uB97C \uB4E4\uC77C \uAC00\uB2A5\uC131\uC774 \uC9C0\uC18D\uC801\uC73C\uB85C
      \uAC70\uB860\uB418\uC5C8\uB2E4. \uC774\uC5D0 \uB530\uB77C \uB300\uC0C1\uC790\uB294
      \uC790\uC2E0\uC758 \uC9C0\uC704\uB97C \uBCF4\uC7A5\uBC1B\uAE30 \uC704\uD574
      \uB2A5\uB825\uC73C\uB85C \uC785\uC9C0\uB97C \uC99D\uBA85\uD574\uC57C \uD55C\uB2E4\uB294
      \uAC15\uD55C \uC555\uBC15 \uC18D\uC5D0\uC11C \uC131\uC7A5\uD558\uC600\uB2E4.
      \uC0AC\uCD0C\uB4E4\uACFC\uC758 \uACBD\uC7C1 \uD658\uACBD \uB610\uD55C \uC0C1\uC2DC
      \uC720\uC9C0\uB418\uC5C8\uC73C\uBA70, \uC774\uB294 \uB300\uC0C1\uC790\uC758
      \uC644\uBCBD\uC8FC\uC758\uC801 \uC131\uD5A5\uACFC \uD1B5\uC81C \uC9C0\uD5A5\uC801
      \uC0AC\uACE0 \uD615\uC131\uC5D0 \uC9C1\uC811\uC801\uC778 \uC601\uD5A5\uC744
      \uC900 \uAC83\uC73C\uB85C \uBCF4\uC778\uB2E4.\n\n\uC57D 10\uC138 \uC804\uD6C4,
      \uC678\uBD80 \uADC0\uC871 \uAC00\uBB38\uACFC\uC758 \uC815\uB7B5 \uC57D\uD63C\uC774
      \uCCB4\uACB0\uB418\uC5C8\uC73C\uB098, \uD574\uB2F9 \uAC00\uBB38\uC774 \uB2E8\uAE30\uAC04
      \uB0B4 \uBAB0\uB77D\uD558\uBA70 \uC57D\uD63C\uC740 \uD574\uC18C\uB418\uC5C8\uB2E4.
      \uC774 \uC0AC\uAC74\uC740 \uB300\uC0C1\uC790\uC5D0\uAC8C \uC720\uC758\uBBF8\uD55C
      \uC2EC\uB9AC\uC801 \uCDA9\uACA9\uC744 \uB0A8\uACBC\uC73C\uBA70, \uC774\uD6C4
      \uAD00\uACC4 \uD615\uC131\uC5D0 \uC788\uC5B4 \uAC10\uC815 \uBC30\uC81C \uBC0F
      \uC2E4\uB9AC \uC911\uC2EC \uD310\uB2E8 \uACBD\uD5A5\uC774 \uAC15\uD654\uB41C
      \uAC83\uC73C\uB85C \uBD84\uC11D\uB41C\uB2E4.\n\n\uC885\uD569\uC801\uC73C\uB85C,
      \uB9AC \uC2DC\uD654\uB294 \uBD88\uC548\uC815\uD55C \uC9C0\uC704\uC640 \uACBD\uC7C1
      \uD658\uACBD \uC18D\uC5D0\uC11C \uC790\uC728\uC801\uC73C\uB85C \uC0DD\uC874
      \uC804\uB7B5\uC744 \uAD6C\uCD95\uD55C \uC0AC\uB840\uB85C \uBCFC \uC218 \uC788\uB2E4.
      \uD604\uC7AC\uC758 \uB0C9\uC815\uD558\uACE0 \uC644\uACB0\uB41C \uD310\uB2E8
      \uAD6C\uC870\uB294, \uACFC\uAC70 \uACBD\uD5D8\uC744 \uAE30\uBC18\uC73C\uB85C
      \uD615\uC131\uB41C \uBC29\uC5B4\uC801 \uC131\uD5A5\uC774\uC790 \uAD8C\uB825
      \uC720\uC9C0 \uC804\uB7B5\uC758 \uC77C\uD658\uC73C\uB85C \uD574\uC11D\uB41C\uB2E4."
  - title: "\uC57D\uD63C \uAD00\uB828 \uAE30\uB85D"
    content: "\uB9AC \uC2DC\uD654\uB294 \uC57D 10\uC138 \uC804\uD6C4, \uC678\uBD80
      \uADC0\uC871 \uAC00\uBB38\uACFC \uBE44\uACF5\uC2DD\uC801\uC778 \uC57D\uD63C
      \uAD00\uACC4\uAC00 \uCD94\uC9C4\uB41C \uBC14 \uC788\uB2E4. \uD574\uB2F9 \uAC00\uBB38\uC740
      \uC624\uB79C \uBA85\uB9DD\uC744 \uC9C0\uB154\uC73C\uB098 \uC815\uCE58\uC801
      \uC601\uD5A5\uB825\uC740 \uD06C\uC9C0 \uC54A\uC558\uC73C\uBA70, \uAD8C\uB825
      \uB2E4\uD23C\uC5D0\uC11C \uD55C\uBC1C \uBB3C\uB7EC\uB09C \uC628\uAC74\uD55C
      \uC131\uD5A5\uC73C\uB85C \uD3C9\uAC00\uB41C\uB2E4. \uAC00\uC8FC\uB97C \uD3EC\uD568\uD55C
      \uAD6C\uC131\uC6D0 \uC804\uBC18\uC774 \uD3C9\uC628\uD55C \uC0B6\uC744 \uC9C0\uD5A5\uD588\uC73C\uBA70,
      \uC774\uB294 \uB9AC \uAC00\uBB38\uACFC \uB300\uBE44\uB418\uB294 \uD2B9\uC9D5\uC73C\uB85C
      \uAE30\uB85D\uB41C\uB2E4.\n\n\uB300\uC0C1\uC790\uB294 \uD574\uB2F9 \uAC00\uBB38\uACFC\uC758
      \uAD50\uB958 \uACFC\uC815\uC5D0\uC11C \uAE30\uC874 \uD658\uACBD\uACFC\uB294
      \uC0C1\uC774\uD55C \uC815\uC11C\uC801 \uACBD\uD5D8\uC744 \uD615\uC131\uD558\uC600\uB2E4.
      \uD2B9\uD788 \uAC00\uC871 \uAC04\uC758 \uC720\uB300\uC640 \uC77C\uC0C1\uC801
      \uAD50\uB958, \uC815\uC6D0\uC5D0\uC11C \uC774\uB8E8\uC5B4\uC9C4 \uAD50\uAC10
      \uB4F1\uC740 \uB300\uC0C1\uC790\uC758 \uC131\uC7A5 \uACFC\uC815\uC5D0\uC11C
      \uB4DC\uBB3C\uAC8C \uD655\uC778\uB418\uB294 \uC548\uC815\uC801 \uAC10\uC815
      \uD615\uC131 \uC0AC\uB840\uB85C \uBD84\uC11D\uB41C\uB2E4. \uC57D\uD63C \uC0C1\uB300
      \uC5ED\uC2DC \uC628\uD654\uD55C \uC131\uACA9\uC73C\uB85C, \uB300\uC0C1\uC790\uC5D0\uAC8C
      \uAE0D\uC815\uC801 \uC778\uC0C1\uC744 \uB0A8\uAE34 \uAC83\uC73C\uB85C \uBCF4\uC778\uB2E4.\n\n\uADF8\uB7EC\uB098
      \uC57D\uD63C\uC774 \uACF5\uC2DD\uD654\uB418\uAE30 \uC774\uC804, \uD574\uB2F9
      \uAC00\uBB38\uC740 \uC815\uCE58 \uC138\uB825 \uAC04 \uCDA9\uB3CC \uACFC\uC815\uC5D0\uC11C
      \uBA78\uBB38\uB418\uC5C8\uB2E4. \uC0AC\uAC74\uC5D0\uB294 \uBCF4\uC218\uD30C
      \uADC0\uC871 \uC138\uB825\uACFC \uD64D\uB828\uADC0\uAC00 \uC5F0\uB8E8\uB41C
      \uAC83\uC73C\uB85C \uD655\uC778\uB418\uBA70, \uC774\uB294 \uB2F9\uC2DC \uAD8C\uB825
      \uC7AC\uD3B8 \uACFC\uC815\uC758 \uC77C\uD658\uC73C\uB85C \uCD94\uC815\uB41C\uB2E4.
      \uB300\uC0C1\uC790\uB294 \uC0AC\uAC74 \uB2F9\uC2DC \uAD6C\uCCB4\uC801 \uB0B4\uB9C9\uC744
      \uC778\uC9C0\uD558\uC9C0 \uBABB\uD588\uC73C\uB098, \uC774\uD6C4 \uC131\uC7A5
      \uACFC\uC815\uC5D0\uC11C \uD574\uB2F9 \uC0AC\uAC74\uC758 \uC815\uCE58\uC801
      \uBC30\uACBD\uC744 \uD30C\uC545\uD558\uAC8C \uB41C \uAC83\uC73C\uB85C \uBCF4\uC778\uB2E4.\n\n\uC0AC\uAC74
      \uC9C1\uD6C4, \uB300\uC0C1\uC790\uC758 \uBD80\uCE5C\uC740 \uC57D\uD63C\uC774
      \uC815\uC2DD\uC73C\uB85C \uCCB4\uACB0\uB418\uC9C0 \uC54A\uC558\uB2E4\uB294
      \uC810\uC744 \uB4E4\uC5B4 \uC0C1\uD669\uC744 \uC2E0\uC18D\uD788 \uC815\uB9AC\uD558\uC600\uC73C\uBA70,
      \uAD00\uB828 \uC0AC\uC2E4\uC740 \uAC00\uBB38 \uB0B4\uBD80\uC5D0\uC11C \uC740\uD3D0\uB418\uC5C8\uB2E4.
      \uC774 \uACFC\uC815\uC5D0\uC11C \uB300\uC0C1\uC790\uB294 \uC2EC\uB9AC\uC801
      \uCDA9\uACA9\uACFC \uD568\uAED8 \uAE30\uC874 \uAC00\uC871\uAD00\uC5D0 \uB300\uD55C
      \uC2E0\uB8B0 \uC800\uD558\uB97C \uACBD\uD5D8\uD55C \uAC83\uC73C\uB85C \uCD94\uC815\uB41C\uB2E4.\n\n\uD574\uB2F9
      \uC0AC\uAC74\uC740 \uB300\uC0C1\uC790\uC758 \uAC00\uCE58\uAD00 \uD615\uC131\uC5D0
      \uC911\uB300\uD55C \uC601\uD5A5\uC744 \uBBF8\uCCE4\uB2E4. \uB300\uC0C1\uC790\uB294
      \uC774\uD6C4 \u201C\uD798\uC774 \uC5C6\uC73C\uBA74 \uC544\uBB34\uAC83\uB3C4
      \uC9C0\uD0AC \uC218 \uC5C6\uB2E4\u201D\uB294 \uC778\uC2DD\uC744 \uD655\uB9BD\uD558\uC600\uC73C\uBA70,
      \uAD8C\uB825 \uD655\uBCF4\uC640 \uC790\uAE30 \uD1B5\uC81C\uC5D0 \uB300\uD55C
      \uC9D1\uCC29\uC774 \uAC15\uD654\uB41C \uC591\uC0C1\uC744 \uBCF4\uC778\uB2E4.
      \uB610\uD55C \uC815\uB7B5 \uACB0\uD63C\uC744 \uD1B5\uD55C \uC138\uB825 \uD655\uC7A5
      \uAC00\uB2A5\uC131\uC744 \uC758\uB3C4\uC801\uC73C\uB85C \uBC30\uC81C\uD558\uB294
      \uC120\uD0DD\uC744 \uC9C0\uC18D\uD558\uACE0 \uC788\uC73C\uBA70, \uC774\uB294
      \uACFC\uAC70 \uACBD\uD5D8\uC5D0 \uAE30\uC778\uD55C \uAC83\uC73C\uB85C \uD310\uB2E8\uB41C\uB2E4.\n\n\uC885\uD569\uC801\uC73C\uB85C,
      \uBCF8 \uC0AC\uAC74\uC740 \uB9AC \uC2DC\uD654\uC758 \uC815\uC11C\uC801 \uB2E8\uC808\uACFC
      \uAD8C\uB825 \uC9C0\uD5A5\uC801 \uC131\uD5A5\uC744 \uAC15\uD654\uC2DC\uD0A8
      \uD575\uC2EC \uAE30\uC810\uC73C\uB85C \uD3C9\uAC00\uB41C\uB2E4."
  - title: "\uC815\uCE58\uC801 \uC774\uB150 \uBC0F \uB178\uC120"
    content: "\uB9AC \uC2DC\uD654\uAC00 \uC18D\uD55C \uB9AC \uAC00\uBB38\uC740 \uC804\uD1B5\uC801\uC778
      \uBCF4\uC218\uD30C \uADC0\uC871 \uC138\uB825\uC73C\uB85C, \uC7A5\uAE30\uAC04
      \uAD6D\uAC00 \uAD8C\uB825\uC758 \uC911\uC2EC\uC744 \uC720\uC9C0\uD574 \uC628
      \uD575\uC2EC \uAC00\uBB38\uC774\uB2E4. \uD574\uB2F9 \uC138\uB825\uC740 \uAD8C\uB825
      \uBD84\uC0B0\uC5D0 \uB300\uD574 \uAC15\uD55C \uACBD\uACC4\uC2EC\uC744 \uBCF4\uC774\uBA70,
      \uD64D\uB828\uADC0\uC640 \uAC19\uC740 \uBE44\uACF5\uC2DD \uC138\uB825\uACFC\uB294
      \uCDA9\uB3CC\uBCF4\uB2E4\uB294 \uACF5\uC874\uC744 \uD0DD\uD558\uB294 \uB178\uC120\uC744
      \uC720\uC9C0\uD574\uC654\uB2E4. \uB610\uD55C \uC678\uBD80 \uC138\uB825\uC758
      \uAC1C\uC785\uC744 \uADF9\uB3C4\uB85C \uBC30\uC81C\uD558\uB294 \uD3D0\uC1C4\uC801
      \uC131\uD5A5\uC774 \uD2B9\uC9D5\uC73C\uB85C \uBD84\uC11D\uB41C\uB2E4.\n\n\uADF8\uB7EC\uB098
      \uCD5C\uADFC \uAD6D\uAC00 \uC9C0\uB3C4\uBD80\uAC00 \uAE09\uC9C4\uD30C \uCD9C\uC2E0\uC73C\uB85C
      \uAD50\uCCB4\uB418\uBA74\uC11C, \uAE30\uC874 \uBCF4\uC218\uD30C \uC911\uC2EC
      \uAD8C\uB825 \uAD6C\uC870\uB294 \uAE09\uACA9\uD788 \uD754\uB4E4\uB9AC\uACE0
      \uC788\uB2E4. \uB9AC \uAC00\uBB38 \uC5ED\uC2DC \uC774\uB7EC\uD55C \uBCC0\uD654
      \uC18D\uC5D0\uC11C \uC815\uCE58\uC801 \uC785\uC9C0 \uC57D\uD654\uB97C \uACAA\uACE0
      \uC788\uC73C\uBA70, \uB0B4\uBD80\uC801\uC73C\uB85C\uB3C4 \uB300\uC751 \uBC29\uD5A5\uC744
      \uB458\uB7EC\uC2FC \uAE34\uC7A5\uC774 \uACE0\uC870\uB41C \uC0C1\uD0DC\uB2E4.\n\n\uC774\uC640
      \uAC19\uC740 \uC0C1\uD669\uC5D0\uC11C \uB9AC \uC2DC\uD654\uB294 \uAC00\uBB38\uC758
      \uACF5\uC2DD \uB178\uC120\uACFC\uB294 \uB2E4\uB978 \uC120\uD0DD\uC744 \uCDE8\uD55C
      \uAC83\uC73C\uB85C \uD655\uC778\uB41C\uB2E4. \uB300\uC0C1\uC790\uB294 \uBCF4\uC218\uD30C
      \uB0B4\uBD80 \uAD8C\uB825 \uAD6C\uC870\uC5D0 \uB300\uD574 \uC2E0\uB8B0\uD558\uC9C0
      \uC54A\uC73C\uBA70, \uD2B9\uD788 \uACFC\uAC70 \uC0AC\uAC74\uC744 \uD1B5\uD574
      \u201C\uAC00\uBB38 \uB0B4 \uAD8C\uB825 \uB610\uD55C \uAC1C\uC778\uC744 \uBCF4\uD638\uD558\uC9C0
      \uC54A\uB294\uB2E4\u201D\uB294 \uC778\uC2DD\uC744 \uD655\uB9BD\uD55C \uAC83\uC73C\uB85C
      \uBCF4\uC778\uB2E4. \uC774\uC5D0 \uB530\uB77C \uADF8\uB294 \uAC00\uBB38\uC758
      \uC601\uD5A5\uB825\uC5D0 \uC758\uC874\uD558\uAE30\uBCF4\uB2E4, \uB3C5\uC790\uC801\uC778
      \uAD8C\uB825 \uAE30\uBC18\uC744 \uAD6C\uCD95\uD558\uB824\uB294 \uBC29\uD5A5\uC73C\uB85C
      \uC804\uB7B5\uC744 \uC218\uC815\uD558\uC600\uB2E4.\n\n\uD604\uC7AC \uB300\uC0C1\uC790\uB294
      \uC678\uBD80\uC801\uC73C\uB85C\uB294 \uBCF4\uC218\uD30C \uADC0\uC871\uC73C\uB85C\uC11C\uC758
      \uC785\uC7A5\uC744 \uC720\uC9C0\uD558\uACE0 \uC788\uC73C\uB098, \uBE44\uACF5\uC2DD\uC801\uC73C\uB85C\uB294
      \uAE09\uC9C4\uD30C \uC9C0\uB3C4\uBD80\uC640\uC758 \uC811\uCD09 \uBC0F \uD611\uB825
      \uAC00\uB2A5\uC131\uC774 \uB192\uC740 \uAC83\uC73C\uB85C \uD310\uB2E8\uB41C\uB2E4.
      \uC774\uB294 \uB2E8\uC21C\uD55C \uC815\uCE58\uC801 \uC804\uD5A5\uC774 \uC544\uB2CC,
      \uAD8C\uB825 \uC7AC\uD3B8 \uACFC\uC815\uC5D0\uC11C \uC8FC\uB3C4\uAD8C\uC744
      \uD655\uBCF4\uD558\uAE30 \uC704\uD55C \uC804\uB7B5\uC801 \uC120\uD0DD\uC73C\uB85C
      \uD574\uC11D\uB41C\uB2E4.\n\n\uD2B9\uD788 \uB300\uC0C1\uC790\uB294 \uAE09\uC9C4\uD30C\uAC00
      \uCD94\uC9C4\uD558\uB294 \uAC1C\uD601 \uB178\uC120\uC744 \uB2E8\uC21C\uD55C
      \uC774\uB150\uC774 \uC544\uB2CC, \uAD6C\uB8E1\uCC44\uC131\uACFC \uD64D\uB828\uADC0
      \uB4F1 \uAE30\uC874 \uCCB4\uC81C\uC758 \uBD88\uC548 \uC694\uC18C\uB97C \uC815\uB9AC\uD560
      \uC218 \uC788\uB294 \uC218\uB2E8\uC73C\uB85C \uC778\uC2DD\uD558\uACE0 \uC788\uB2E4.
      \uC774\uB294 \uAC1C\uC778\uC801 \uACBD\uD5D8\uACFC \uACB0\uD569\uB41C \uD604\uC2E4\uC801
      \uD310\uB2E8\uC73C\uB85C, \uBCC0\uD654 \uC790\uCCB4\uBCF4\uB2E4\uB294 \u201C\uD1B5\uC81C
      \uAC00\uB2A5\uD55C \uC9C8\uC11C \uC7AC\uAD6C\uCD95\u201D\uC5D0 \uBAA9\uC801\uC774
      \uC788\uB294 \uAC83\uC73C\uB85C \uBD84\uC11D\uB41C\uB2E4.\n\n\uC885\uD569\uC801\uC73C\uB85C,
      \uB9AC \uC2DC\uD654\uB294 \uD45C\uBA74\uC801\uC73C\uB85C\uB294 \uBCF4\uC218\uD30C
      \uC9C8\uC11C\uB97C \uC720\uC9C0\uD558\uBA74\uC11C\uB3C4, \uC2E4\uC9C8\uC801\uC73C\uB85C\uB294
      \uAE09\uC9C4\uD30C\uB97C \uD65C\uC6A9\uD574 \uAD8C\uB825 \uAD6C\uC870\uB97C
      \uC7AC\uD3B8\uD558\uB824\uB294 \uC774\uC911\uC801 \uC804\uB7B5\uC744 \uCDE8\uD558\uACE0
      \uC788\uB2E4. \uC774\uB294 \uAC00\uBB38 \uB0B4 \uAD8C\uB825 \uC2B9\uACC4\uC640
      \uAD6D\uAC00 \uAD8C\uB825 \uD655\uBCF4\uB97C \uB3D9\uC2DC\uC5D0 \uB178\uB9AC\uB294
      \uACE0\uC704\uD5D8\xB7\uACE0\uD6A8\uC728 \uC804\uB7B5\uC73C\uB85C \uD3C9\uAC00\uB41C\uB2E4."
  - title: "\uC9C1\uBB34 \uC774\uB825 \uBC0F \uBC30\uCE58 \uACBD\uC704"
    content: "\uB9AC \uC2DC\uD654\uB294 \uBA85\uB9DD \uB192\uC740 \uB9AC \uAC00\uBB38\uC758
      \uC678\uB3D9\uB538\uB85C \uCD9C\uC0DD\uD558\uC5EC, \uC720\uB144\uAE30\uBD80\uD130
      \uADC0\uC871 \uAD50\uC721\uACFC \uC815\uCE58\uC801 \uC18C\uC591\uC744 \uCCB4\uACC4\uC801\uC73C\uB85C
      \uC2B5\uB4DD\uD558\uC600\uB2E4. \uB6F0\uC5B4\uB09C \uD559\uBB38\uC801 \uC131\uCDE8\uC640
      \uD310\uB2E8\uB825\uC744 \uBC14\uD0D5\uC73C\uB85C \uC911\uC559 \uC815\uACC4\uC5D0
      \uBE60\uB974\uAC8C \uC9C4\uC785\uD588\uC73C\uBA70, \uB2E8\uAE30\uAC04 \uB0B4
      \uAD6D\uAC00 \uD575\uC2EC \uAE30\uAD00\uC778 \uC911\uC559\uCCAD \uCC38\uC0AC
      \uC9C1\uC704\uC5D0 \uC624\uB974\uBA70 \uCC28\uC138\uB300 \uC815\uCE58 \uC778\uBB3C\uB85C
      \uC8FC\uBAA9\uBC1B\uC558\uB2E4.\n\n\uADF8\uB7EC\uB098 \uD2B9\uC815 \uC0AC\uAC74
      \uC774\uD6C4, \uB300\uC0C1\uC790\uB294 \uACF5\uC791\uCCAD \uCC28\uAD00 \uBCF4\uC88C
      \uC9C1\uC704\uB85C \uC804\uACA9 \uBC1C\uB839\uB418\uC5C8\uB2E4. \uC911\uC559\uCCAD
      \uCC38\uC0AC\uC5D0\uC11C\uC758 \uC774\uB3D9\uC740 \uD1B5\uC0C1\uC801\uC778
      \uC778\uC0AC \uAE30\uC900\uC73C\uB85C \uBCFC \uB54C \uBA85\uBC31\uD55C \uAC15\uB4F1\uC5D0
      \uD574\uB2F9\uD558\uBA70, \uC678\uBD80\uC5D0\uC11C\uB294 \uC774\uB97C \uC88C\uCC9C\uC73C\uB85C
      \uC778\uC2DD\uD558\uACE0 \uC788\uB2E4. \uD2B9\uD788 \uB2F9\uC2DC \uC9C0\uB3C4\uBD80\uAC00
      \uAE09\uC9C4\uD30C\uC600\uACE0, \uB9AC \uAC00\uBB38\uC774 \uBCF4\uC218\uD30C
      \uD575\uC2EC \uC138\uB825\uC774\uB77C\uB294 \uC810\uC5D0\uC11C \u201C\uC815\uCE58\uC801
      \uACAC\uC81C\u201D \uD639\uC740 \u201C\uC758\uB3C4\uC801 \uCD95\uCD9C\u201D\uC774\uB77C\uB294
      \uD574\uC11D\uC774 \uC9C0\uBC30\uC801\uC774\uB2E4.\n\n\uC77C\uBD80\uC5D0\uC11C\uB294
      \uACF5\uC791\uCCAD \uC7A5\uAD00\uC774 \uB3D9\uC77C \uAC00\uBB38 \uC778\uC0AC\uB77C\uB294
      \uC810\uC744 \uB4E4\uC5B4 \uCD5C\uC18C\uD55C\uC758 \uBCF4\uD638 \uC870\uCE58\uB85C
      \uD574\uC11D\uD558\uAE30\uB3C4 \uD558\uB098, \uC804\uBC18\uC801\uC73C\uB85C
      \uB300\uC0C1\uC790\uC5D0 \uB300\uD55C \uD3C9\uAC00\uB294 \u201C\uAD8C\uB825\uC5D0\uC11C
      \uBC00\uB824\uB09C \uC778\uBB3C\u201D\uB85C \uC218\uB834\uB418\uACE0 \uC788\uB2E4.
      \uC774\uB294 \uC815\uCE58\uC801 \uC601\uD5A5\uB825 \uC57D\uD654\uC5D0 \uB530\uB978
      \uC0C1\uC9D5\uC801 \uC0AC\uB840\uB85C \uD65C\uC6A9\uB418\uB294 \uACBD\uD5A5\uC774
      \uC788\uB2E4.\n\n\uADF8\uB7EC\uB098 \uB0B4\uBD80 \uC815\uBCF4\uC5D0 \uB530\uB974\uBA74,
      \uD574\uB2F9 \uC778\uC0AC\uB294 \uD45C\uBA74\uC801 \uC88C\uCC9C\uACFC\uB294
      \uC131\uACA9\uC774 \uB2E4\uB978 \uAC83\uC73C\uB85C \uD655\uC778\uB41C\uB2E4.
      \uB9AC \uC2DC\uD654\uB294 \uD604 \uC9C0\uB3C4\uBD80\uB85C\uBD80\uD130 \uBE44\uACF5\uC2DD\uC801
      \uC2E0\uC784\uC744 \uBD80\uC5EC\uBC1B\uC740 \uC0C1\uD0DC\uC774\uBA70, \uAD6C\uB8E1\uCC44\uC131
      \uC9C0\uC5ED\uC758 \uD1B5\uC81C \uBC0F \uD589\uC815 \uD3B8\uC785\uC744 \uC704\uD55C
      \uC0AC\uC804 \uC815\uB9AC \uC784\uBB34\uB97C \uC218\uD589 \uC911\uC778 \uAC83\uC73C\uB85C
      \uD310\uB2E8\uB41C\uB2E4. \uACF5\uC791\uCCAD \uCC28\uAD00 \uBCF4\uC88C \uC9C1\uC704\uB294
      \uD574\uB2F9 \uC784\uBB34 \uC218\uD589\uC744 \uC704\uD55C \uC704\uC7A5 \uC778\uC0AC\uB85C,
      \uC678\uBD80 \uC2DC\uC120\uC744 \uCC28\uB2E8\uD558\uAE30 \uC704\uD55C \uBAA9\uC801\uC774
      \uAC15\uD558\uB2E4.\n\n\uD574\uB2F9 \uC784\uBB34\uB294 \uAE30\uC874 \uAD8C\uB825
      \uAD6C\uC870\uC640 \uCDA9\uB3CC \uAC00\uB2A5\uC131\uC774 \uB192\uC740 \uACE0\uC704\uD5D8
      \uC5C5\uBB34\uB85C \uBD84\uB958\uB418\uBA70, \uB300\uC0C1\uC790\uC758 \uC815\uCE58\uC801
      \uC785\uC9C0 \uBC0F \uAC00\uBB38\uACFC\uC758 \uAD00\uACC4\uC5D0\uB3C4 \uC601\uD5A5\uC744
      \uBBF8\uCE60 \uC218 \uC788\uB2E4. \uD604\uC7AC\uAE4C\uC9C0 \uC774\uC640 \uAD00\uB828\uB41C
      \uC815\uBCF4\uB294 \uADF9\uBE44 \uC218\uC900\uC73C\uB85C \uC720\uC9C0\uB418\uACE0
      \uC788\uC73C\uBA70, \uAC00\uBB38 \uB0B4\uBD80\uC5D0\uC11C\uB3C4 \uACF5\uC720\uB418\uC9C0
      \uC54A\uC740 \uAC83\uC73C\uB85C \uCD94\uC815\uB41C\uB2E4.\n\n\uC885\uD569\uC801\uC73C\uB85C,
      \uB9AC \uC2DC\uD654\uB294 \uC678\uBD80\uC801\uC73C\uB85C\uB294 \uC88C\uCC9C\uB41C
      \uAD00\uB8CC\uB85C \uC778\uC2DD\uB418\uC9C0\uB9CC, \uC2E4\uC81C\uB85C\uB294
      \uC9C0\uB3C4\uBD80\uC758 \uBE44\uACF5\uC2DD \uC9C0\uC2DC\uB97C \uC218\uD589\uD558\uB294
      \uACE0\uC704 \uC804\uB7B5 \uC778\uB825\uC73C\uB85C \uAE30\uB2A5\uD558\uACE0
      \uC788\uB2E4."
  relations:
  - targetCharacter: {fileID: 11400000, guid: 28c49b0d7acc406409bf904082253a32, type: 2}
    characterName: "\uB9AC \uCC3D\uC720"
    comment: "\uC2DC\uAC04 \uC880 \uB354 \uC8FC\uBA74, \uC774\uB984\uAC12 \uC81C\uB300\uB85C
      \uD560 \uAC70\uC57C. \uADF8\uAC74 \uB0B4\uAC00 \uC7A5\uB2F4\uD574."
  - targetCharacter: {fileID: 11400000, guid: b3ad0f2b1050edb449acb7acda6d0087, type: 2}
    characterName: "\uC8FC \uCCAD\uD654"
    comment: "\uB2E4\uD589\uC774\uB2E4, \uB108\uB294 \uADF8\uB300\uB85C\uB77C\uC11C."
