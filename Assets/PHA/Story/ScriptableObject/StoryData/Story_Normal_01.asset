  - nodeId: appointment_choice_001
    nodeType: 3
    text: 
    character: {fileID: 11400000, guid: a778268b0982c7d4bae2b7d849161739, type: 2}
    portraitId: D_01_00
    nextNodeId: appointment_narration_001
    choices:
    - choiceText: "\uC194\uC9C1\uD788 \uB9D0\uD574\uC11C, \uCD5C\uC545\uC5D0 \uAC00\uAE4C\uC6E0\uC2B5\uB2C8\uB2E4.
        \uC774\uACF3\uC5D4 \uADDC\uCE59\uB3C4 \uC5C6\uACE0, \uBB34\uC9C8\uC11C\uD55C
        \uACF3\uC774\uB2C8\uAE4C\uC694."
      targetNodeId: appointment_narration_001
      resultKey: 
      resultValue: 
    - choiceText: "\uC544\uC9C1\uC740 \uD310\uB2E8\uD558\uAE30 \uC5B4\uB835\uC2B5\uB2C8\uB2E4.
        \uC870\uAE08 \uB354 \uACAA\uC5B4\uBD10\uC57C \uC81C\uB300\uB85C \uC54C \uC218
        \uC788\uACA0\uC8E0."
      targetNodeId: appointment_narration_001
      resultKey: 
      resultValue: 
    - choiceText: "\uC0DD\uAC01\uBCF4\uB2E4 \uAD1C\uCC2E\uC740 \uACF3\uC778 \uAC83
        \uAC19\uC2B5\uB2C8\uB2E4. \uB098\uB984 \uC9C8\uC11C\uB3C4 \uC788\uACE0, \uC0AC\uB78C\uB4E4\uB3C4
        \uAD1C\uCC2E\uC740 \uAC83 \uAC19\uACE0\uC694."
      targetNodeId: appointment_narration_001
      resultKey: 
      resultValue: 
    dimPortrait: 1
    keepPortrait: 1
    useTypingEffect: 0
    autoAdvance: 0
    autoAdvanceDelay: 0
    effects: []
  - nodeId: appointment_narration_001
    nodeType: 2
    text: "(\uB9AC \uC2DC\uD654\uB294 \uACE0\uAC1C\uB97C \uB044\uB355\uC600\uC9C0\uB9CC,
      \uADF8 \uD45C\uC815\uC5D0\uB294 \uBCC4\uB2E4\uB978 \uAC10\uD765\uC774 \uC5C6\uC5B4
      \uBCF4\uC600\uB2E4.)"
    character: {fileID: 11400000, guid: a778268b0982c7d4bae2b7d849161739, type: 2}
    portraitId: D_01_00
    nextNodeId: appointment_005
    choices: []
    dimPortrait: 1
    keepPortrait: 1
    useTypingEffect: 0
    autoAdvance: 0
    autoAdvanceDelay: 0
    effects: []
  - nodeId: appointment_005
    nodeType: 0
    text: "\uAD6C\uB8E1\uCC44\uC131 \uCD9C\uC2E0\uC774\uB77C\uACE0 \uB4E4\uC5C8\uC2B5\uB2C8\uB2E4.
      \uADF8\uB7F0 \uBC30\uACBD\uC774 \uAC10\uC0C1\uC5D0 \uC601\uD5A5\uC744 \uC92C\uC744
      \uC218\uB3C4 \uC788\uACA0\uAD70\uC694."
    character: {fileID: 11400000, guid: a778268b0982c7d4bae2b7d849161739, type: 2}
    portraitId: D_01_00
    nextNodeId: appointment_006
    choices: []
    dimPortrait: 0
    keepPortrait: 1
    useTypingEffect: 0
