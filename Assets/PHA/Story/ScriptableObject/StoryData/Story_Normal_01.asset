    effects: []
  - nodeId: appointment_narration_002
    nodeType: 2
    text: "(\uB9AC \uC2DC\uD654\uB294 \uCC45\uC0C1 \uC704\uC5D0 \uAD6C\uB8E1\uCC44\uC131\uC758
      \uAD6C\uC870\uB3C4\uB97C \uD3BC\uCCE4\uB2E4.)"
