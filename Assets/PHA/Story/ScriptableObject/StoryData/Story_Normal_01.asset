    effects: []
  - nodeId: appointment_003
    nodeType: 0
    text: "\uC55E\uC73C\uB85C \uC81C3\uC7AC\uAC74\uC9C0\uAD6C\uC758 \uBAA8\uB4E0
      \uC791\uC5C5 \uBCF4\uACE0\uB294 \uC800\uC5D0\uAC8C \uC9C1\uC811 \uD558\uC2DC\uBA74
