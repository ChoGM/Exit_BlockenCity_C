    effects: []
  - nodeId: appointment_004
    nodeType: 0
    text: "\uBD80\uC784\uD55C \uC9C0 \uD55C \uB2EC \uC815\uB3C4 \uB418\uC168\uC8E0.
      \uC774\uACF3\uC740 \uC5B4\uB5BB\uC2B5\uB2C8\uAE4C."
