    autoAdvanceDelay: 0
    effects: []
  - nodeId: appointment_006
    nodeType: 0
    text: "\uD558\uC9C0\uB9CC \uADF8\uAC74 \uC911\uC694\uD558\uC9C0 \uC54A\uC2B5\uB2C8\uB2E4.
      \uCD9C\uC2E0\uBCF4\uB2E4 \uC911\uC694\uD55C \uAC74, \uC55E\uC73C\uB85C \uB2F9\uC2E0\uC774
      \uC5B4\uB5BB\uAC8C \uD589\uB3D9\uD558\uB290\uB0D0\uC785\uB2C8\uB2E4."
    character: {fileID: 11400000, guid: a778268b0982c7d4bae2b7d849161739, type: 2}
