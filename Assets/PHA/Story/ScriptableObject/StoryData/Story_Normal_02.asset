  - nodeId: Narration_01
    nodeType: 2
    text: "(\uB9AC \uC2DC\uD654\uAC00 \uBCC4 \uB2E4\uB97C \uBC18\uC751 \uC5C6\uC774
      \uADF8\uC800 \uACE0\uAC1C\uB97C \uB044\uB355\uC600\uB2E4.)"
    character: {fileID: 11400000, guid: a778268b0982c7d4bae2b7d849161739, type: 2}
