    effects: []
  - nodeId: Sihwa_08
    nodeType: 0
    text: "\uC774\uACF3\uC740 \uB2F9\uC2E0\uC758 \uC9C1\uC7A5\uC785\uB2C8\uB2E4.
      \uB2F9\uC2E0\uC758 \uC5F0\uBBFC\uB3C4, \uC120\uC758\uB3C4, \uAC1C\uC778\uC801\uC778
      \uC2E0\uB150\uB3C4. \uC774\uACF3\uC5D0\uC11C\uB294 \uACE0\uB824 \uB300\uC0C1\uC774
      \uC544\uB2D9\uB2C8\uB2E4."
