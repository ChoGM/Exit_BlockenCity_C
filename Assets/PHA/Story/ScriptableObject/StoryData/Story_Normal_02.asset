    effects: []
  - nodeId: Sihwa_09
    nodeType: 0
    text: "\uD55C \uC0AC\uB78C\uC744 \uBC1B\uC544\uB4E4\uC774\uB294 \uAC83\uC740
      \uD55C \uCC44\uC758 \uC9D1\uB9CC \uBE44\uC6B0\uB294 \uC77C\uC774 \uC544\uB2D9\uB2C8\uB2E4.
      \uC2DD\uB7C9\uACFC \uC790\uC7AC, \uC778\uB825, \uCE58\uC548\uAE4C\uC9C0 \uBAA8\uB450
      \uB2E4\uC2DC \uACC4\uC0B0\uD574\uC57C \uD558\uC8E0."
