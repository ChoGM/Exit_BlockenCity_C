    effects: []
  - nodeId: Sihwa_02
    nodeType: 0
    text: "\uB3D9\uCABD \uAD6C\uC5ED\uC758 \uAC74\uBB3C \uB2E4\uC218\uAC00 \uBD95\uAD34\uD588\uB2E4\uB294
      \uBCF4\uACE0\uB294 \uC774\uBBF8 \uBC1B\uC558\uC2B5\uB2C8\uB2E4."
